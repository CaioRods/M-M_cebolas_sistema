# Nginx - Proxy reverso para M&M Cebolas
# Servidor: Ubuntu 24.04 | Node na porta 3000
# Coloque em /etc/nginx/sites-available/ e ative com symlink em sites-enabled.
# Certificado emitido via: certbot --nginx -d portalmmcebolas.com -d www.portalmmcebolas.com

# HTTPS - domínio oficial (certificado Let's Encrypt)
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name portalmmcebolas.com www.portalmmcebolas.com;

    client_max_body_size 15m;

    ssl_certificate /etc/letsencrypt/live/portalmmcebolas.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/portalmmcebolas.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location = / {
        return 302 /pages/login.html;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# HTTP - redireciona o domínio para HTTPS, mas serve normalmente por IP puro
# (fallback usado pelo app Electron enquanto não há certificado para o IP)
server {
    listen 80;
    listen [::]:80;
    server_name 85.31.231.151 portalmmcebolas.com www.portalmmcebolas.com;

    client_max_body_size 15m;

    if ($host = portalmmcebolas.com) {
        return 301 https://$host$request_uri;
    }
    if ($host = www.portalmmcebolas.com) {
        return 301 https://$host$request_uri;
    }

    location = / {
        return 302 /pages/login.html;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
