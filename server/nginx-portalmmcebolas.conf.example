# Nginx - Proxy reverso para M&M Cebolas
# Servidor: Ubuntu 24.04 | Node na porta 3000
# Coloque em /etc/nginx/sites-available/ e ative com symlink em sites-enabled.

# HTTP - acesso via IP (sem certificado) e redirecionamento do domínio para HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name 85.31.231.151 portalmmcebolas.com www.portalmmcebolas.com;

    # Depois que o certbot rodar, ele adiciona automaticamente o redirect
    # https://portalmmcebolas.com aqui. Acesso via IP continua em HTTP puro.

    location = / {
        return 302 /pages/login.html;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

