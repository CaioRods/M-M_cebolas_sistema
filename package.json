{
  "name": "sistema-cebolas",
  "version": "0.1.2",
  "description": "Sistema de Controle de Estoque M&M Cebolas",
  "main": "frontend/main.js",
  "scripts": {
    "dev": "node dev.js",
    "local": "node dev.js",
    "offline": "node dev.js",
    "start": "electron .",
    "serve": "node server/server.js",
    "build": "electron-builder build",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "build:all": "electron-builder build -mw",
    "publish": "electron-builder build --publish always",
    "install:all": "npm install && cd server && npm install"
  },
  "author": "M&M Cebolas",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mmcebolas.sistema",
    "productName": "M&M Cebolas",
    "directories": {
      "output": "dist"
    },
    "files": [
      "frontend/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "CaioRods",
        "repo": "M-M_cebolas_sistema"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "frontend/Imgs/Logo_M&M_Cebolas.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "frontend/Imgs/Logo_M&M_Cebolas.png",
      "uninstallerIcon": "frontend/Imgs/Logo_M&M_Cebolas.png",
      "shortcutName": "M&M Cebolas"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "icon": "frontend/Imgs/apple-icon.png"
    }
  }
}
